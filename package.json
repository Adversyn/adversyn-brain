{
  "name": "adversyn-autonomous-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous GitHub bridge tooling for the Adversyn brain repo (CI workflow, Playwright autonomous site QA, PR comment automation).",
  "type": "module",
  "scripts": {
    "qa:e2e": "playwright test",
    "qa:report": "node scripts/generate-qa-report.mjs",
    "qa:full": "playwright test && node scripts/generate-qa-report.mjs",
    "pm:create-issue": "node scripts/create-github-issue-from-nova.mjs",
    "pm:create-issue:sample-claude": "node scripts/create-github-issue-from-nova.mjs examples/nova-task-claude.json --dry-run",
    "pm:create-issue:sample-codex": "node scripts/create-github-issue-from-nova.mjs examples/nova-task-codex.json --dry-run",
    "pm:create-issue:sample-qa": "node scripts/create-github-issue-from-nova.mjs examples/nova-task-qa.json --dry-run",
    "pm:watch": "node scripts/watch-nova-inbox.mjs --watch",
    "pm:watch:once": "node scripts/watch-nova-inbox.mjs",
    "pm:review": "node scripts/review-github-task-for-darren.mjs",
    "pm:watch-results": "node scripts/watch-github-results-for-darren.mjs --watch",
    "pm:watch-results:once": "node scripts/watch-github-results-for-darren.mjs",
    "pm:watch-agents": "node scripts/watch-agent-issues.mjs --watch",
    "pm:watch-agents:once": "node scripts/watch-agent-issues.mjs",
    "pm:watch-agents:dry-run": "node scripts/watch-agent-issues.mjs --dry-run"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.14.0"
  }
}
